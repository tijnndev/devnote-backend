# -----------------------------------------------------------------------------
# DevNote Backend Environment Template
# -----------------------------------------------------------------------------
# Copy this file to .env and replace values for your environment.

# -----------------------------------------------------------------------------
# App Runtime
# -----------------------------------------------------------------------------
# NODE_ENV: development | test | production
NODE_ENV=development

# PORT: backend HTTP server port.
PORT=8037

# -----------------------------------------------------------------------------
# Database
# -----------------------------------------------------------------------------
# DATABASE_URL: database connection URI.
# MySQL example: mysql://root:password@localhost:3306/devnote
DATABASE_URL="mysql://root:password@localhost:3306/devnote"

# -----------------------------------------------------------------------------
# Security / Access Control
# -----------------------------------------------------------------------------
# API_KEY: required x-api-key header value for protected routes.
# Use a long random value (32+ chars recommended).
API_KEY=replace_with_a_long_random_secret

# ALLOWED_ORIGINS: comma-separated list of browser origins allowed by CORS.
# Include your frontend URL(s).
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:4173

# -----------------------------------------------------------------------------
# Optional Integrations
# -----------------------------------------------------------------------------
# SYNC_WEBHOOK_URL: optional endpoint to receive sync notifications.
# Leave empty to disable.
SYNC_WEBHOOK_URL=http://localhost:4000/api/sync
