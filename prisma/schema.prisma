generator client {
	provider = "prisma-client-js"
}

datasource db {
	provider = "mysql"
	url      = env("DATABASE_URL")
}

model Folder {
	id          String    @id @default(cuid())
	parentId    String?
	parent      Folder?   @relation("FolderHierarchy", fields: [parentId], references: [id], onDelete: Cascade)
	children    Folder[]  @relation("FolderHierarchy")
	title       String
	description String?   @db.Text
	color       String?
	position    Int       @default(0)
	pages       Page[]
	createdAt   DateTime   @default(now())
	updatedAt   DateTime   @updatedAt

	@@index([parentId, position])
}

model Page {
	id          String       @id @default(cuid())
	folderId    String?
	folder      Folder?      @relation(fields: [folderId], references: [id], onDelete: SetNull)
	title       String
	slug        String?      @unique
	position    Int          @default(0)
	searchText  String       @default("") @db.Text
	isPinned    Boolean      @default(false)
	isArchived  Boolean      @default(false)
	content     PageContent?
	revisions   PageRevision[]
	createdAt   DateTime     @default(now())
	updatedAt   DateTime     @updatedAt

	@@index([folderId, position])
}

model PageContent {
	id         String   @id @default(cuid())
	pageId     String   @unique
	html       String   @default("") @db.LongText
	json       String?  @db.LongText
	text       String   @default("") @db.Text
	canvasJson String?  @db.LongText
	createdAt  DateTime @default(now())
	updatedAt  DateTime @updatedAt
	page       Page     @relation(fields: [pageId], references: [id], onDelete: Cascade)
}

model PageRevision {
	id        String   @id @default(cuid())
	pageId    String
	page      Page     @relation(fields: [pageId], references: [id], onDelete: Cascade)
	snapshot  String   @db.LongText
	createdAt DateTime @default(now())

	@@index([pageId, createdAt])
}

model SyncState {
	id           String   @id @default(cuid())
	clientId     String
	cursor       String   @unique
	lastSyncedAt DateTime @default(now())
	createdAt    DateTime @default(now())
	updatedAt    DateTime @updatedAt

	@@unique([clientId])
}

model ChangeLog {
	id         String   @id @default(cuid())
	entityType String
	entityId   String
	action     String
	payload    String   @db.LongText
	createdAt  DateTime @default(now())

	@@index([entityType, entityId])
	@@index([createdAt])
}
