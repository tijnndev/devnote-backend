generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model changelog {
  id         String   @id
  entityType String
  entityId   String
  action     String
  payload    String   @db.LongText
  createdAt  DateTime @default(now())

  @@index([createdAt], map: "ChangeLog_createdAt_idx")
  @@index([entityType, entityId], map: "ChangeLog_entityType_entityId_idx")
}

model folder {
  id           String   @id
  parentId     String?
  title        String
  description  String?  @db.Text
  color        String?
  position     Int      @default(0)
  createdAt    DateTime @default(now())
  updatedAt    DateTime
  folder       folder?  @relation("folderTofolder", fields: [parentId], references: [id], onDelete: Cascade, map: "Folder_parentId_fkey")
  other_folder folder[] @relation("folderTofolder")
  page         page[]

  @@index([parentId, position], map: "Folder_parentId_position_idx")
}

model page {
  id           String         @id
  folderId     String?
  title        String
  slug         String?        @unique(map: "Page_slug_key")
  position     Int            @default(0)
  searchText   String         @default("") @db.Text
  isPinned     Boolean        @default(false)
  isArchived   Boolean        @default(false)
  createdAt    DateTime       @default(now())
  updatedAt    DateTime
  folder       folder?        @relation(fields: [folderId], references: [id], map: "Page_folderId_fkey")
  pagecontent  pagecontent?
  pagerevision pagerevision[]

  @@index([folderId, position], map: "Page_folderId_position_idx")
}

model pagecontent {
  id         String   @id
  pageId     String   @unique(map: "PageContent_pageId_key")
  html       String   @default("") @db.LongText
  json       String?  @db.LongText
  text       String   @default("") @db.Text
  canvasJson String?  @db.LongText
  createdAt  DateTime @default(now())
  updatedAt  DateTime
  page       page     @relation(fields: [pageId], references: [id], onDelete: Cascade, map: "PageContent_pageId_fkey")
}

model pagerevision {
  id        String   @id
  pageId    String
  snapshot  String   @db.LongText
  createdAt DateTime @default(now())
  page      page     @relation(fields: [pageId], references: [id], onDelete: Cascade, map: "PageRevision_pageId_fkey")

  @@index([pageId, createdAt], map: "PageRevision_pageId_createdAt_idx")
}

model syncstate {
  id           String   @id
  clientId     String   @unique(map: "SyncState_clientId_key")
  cursor       String   @unique(map: "SyncState_cursor_key")
  lastSyncedAt DateTime @default(now())
  createdAt    DateTime @default(now())
  updatedAt    DateTime
}
