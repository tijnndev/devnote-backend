{
	"name": "devnote-backend",
	"version": "0.1.0",
	"private": true,
	"type": "module",
	"main": "dist/server.js",
	"scripts": {
			"dev": "cross-env NODE_ENV=development tsx watch src/server.ts",
		"build": "tsc -p tsconfig.json",
			"start": "node dist/server.js",
		"lint": "eslint \"src/**/*.{ts,tsx}\"",
		"prepare": "prisma generate",
		"prisma:migrate": "prisma migrate dev",
		"prisma:studio": "prisma studio",
			"test": "cross-env NODE_ENV=test DATABASE_URL=file:./devnote-test.db vitest run",
			"test:watch": "cross-env NODE_ENV=test DATABASE_URL=file:./devnote-test.db vitest"
	},
	"engines": {
		"node": ">=18.17.0",
		"npm": ">=9.8.0"
	},
	"dependencies": {
		"@prisma/client": "^5.16.1",
		"cors": "^2.8.5",
		"dotenv": "^16.4.5",
		"express": "^4.19.2",
		"helmet": "^7.1.0",
		"pino": "^9.2.0",
		"pino-pretty": "^11.2.2",
		"zod": "^3.23.8"
	},
	"devDependencies": {
		"@types/cors": "^2.8.17",
		"@types/express": "^4.17.21",
		"@types/node": "^20.14.11",
			"@types/supertest": "^2.0.16",
		"@typescript-eslint/eslint-plugin": "^7.15.0",
		"@typescript-eslint/parser": "^7.15.0",
			"cross-env": "^7.0.3",
		"eslint": "^8.57.1",
		"eslint-config-prettier": "^9.1.0",
		"eslint-plugin-import": "^2.29.1",
		"prisma": "^5.16.1",
			"supertest": "^6.3.4",
		"tsx": "^4.19.1",
		"typescript": "^5.5.4",
		"vitest": "^1.6.0"
	}
}
